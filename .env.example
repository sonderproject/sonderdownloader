# Optional: override the remote Chromium pack URL used by
# @sparticuz/chromium-min on serverless. Defaults to the pinned v131 pack.
# CHROMIUM_PACK_URL=https://github.com/Sparticuz/chromium/releases/download/v131.0.1/chromium-v131.0.1-pack.tar

# Optional: local Chromium executable path used only during `next dev`.
# CHROMIUM_EXECUTABLE_PATH=/opt/pw-browsers/chromium
